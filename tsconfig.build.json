{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "moduleResolution": "bundler"
  },
  "include": ["src"],
  "exclude": ["example", "node_modules", "dist"]
}
